# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# n8n — browser posts resume + video here (Production URL from Webhook node)
NEXT_PUBLIC_N8N_SCREEN_WEBHOOK_URL=

# n8n callback — must match header x-webhook-secret on POST /api/screenings/callback
N8N_CALLBACK_SECRET=

# App URL (used in n8n HTTP Request node for callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
